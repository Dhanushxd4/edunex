# Railway PostgreSQL (auto-injected by Railway)
DATABASE_URL=postgresql://user:password@host:port/dbname

# JWT Secret (generate a strong random string)
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random
JWT_EXPIRES_IN=7d

# Server
PORT=3001
NODE_ENV=production

# CORS - set to your Vercel frontend URL
CORS_ORIGIN=https://your-edunex.vercel.app

# YouTube API (free - https://console.cloud.google.com)
YOUTUBE_API_KEY=your_youtube_api_key

# Email (SMTP - use Gmail free or Mailtrap for testing)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# App URL
APP_URL=https://your-edunex-api.railway.app
