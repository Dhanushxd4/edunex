# Copy this to .env and fill in real values
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend URL — leave blank in dev (Vite proxy handles it)
# In Vercel env vars set this to your Railway backend URL:
# e.g. https://edunex-api.up.railway.app
VITE_API_URL=
